TooltipManager="*uid://b5dpsnkjuq35o"
PlayerManager="*uid://cr0ehaih2ydy6"
LevelManager="*uid://c3e1mhvhxt8y6"
SaveManager="*uid://cl4xqarhgi8bd"
ThemeManager="*uid://cc3op3ntw3kw6"
MaterialManager="*uid://cohud5py8spkb"

