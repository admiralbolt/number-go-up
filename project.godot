config_version=5

[application]

config/name="number-go-up"
run/main_scene="uid://crp31gygqd1uv"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

SignalBus="*uid://ccoafian0chyt"
WeaponManager="*uid://bytvljuc6bnme"
SceneTransition="*uid://x28qgxagmoqx"
PauseMenu="*uid://bi0j0pp4w8exd"
